{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main Caduceus window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "core:event:default",
    "shell:default",
    "dialog:allow-open",
    "updater:default",
    "notification:default",
    "process:default",
    "single-instance:default"
  ]
}
