{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Corey",
  "version": "0.1.9",
  "identifier": "com.caduceus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Control plane for AI agents",
    "longDescription": "Corey is a desktop control plane for AI agents. Chat with Hermes, route messages across adapters, manage MCP servers, budgets, skills, and scheduled jobs — all locally, no cloud sync.",
    "publisher": "Corey Contributors",
    "homepage": "https://github.com/zbin0929/CoreyOS",
    "createUpdaterArtifacts": true,
    "resources": [
      "assets/presets/**/*",
      "scripts/browser-runner.cjs",
      "assets/scripts/bootstrap-windows.ps1",
      "assets/scripts/bootstrap-macos.sh"
    ],
    "macOS": {
      "infoPlist": "../src-tauri/macos.Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://corey-update-1259005327.cos.ap-guangzhou.myqcloud.com/releases/latest.json",
        "https://github.com/zbin0929/CoreyOS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGNzk2RTM5NTY5N0IxN0UKUldSK3NaZFdPVzU1ajB0TjdKZGlVajcvZTg1NUJvSzVIRFUxaWcwRzdOR2tqWkRKZWt1SWpQT1MK"
    }
  }
}
